{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API",
      "runtimeExecutable": "pnpm",
      "program": "${workspaceFolder}/dist/src/server.js",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "runtimeArgs": ["run", "dev"],
      "sourceMaps": true,
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}